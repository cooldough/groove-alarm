    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-view-shot": "^3.8.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.1.3"
  },
  "private": true
}
